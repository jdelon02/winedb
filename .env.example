# Wine Collection App Environment Variables

# Wine-Searcher API Configuration
WINE_SEARCHER_API_KEY=your_wine_searcher_api_key_here
WINE_SEARCHER_BASE_URL=https://api.wine-searcher.com/v1
ENABLE_WINE_SEARCHER=false

# Global Wine Score API Configuration
GLOBAL_WINE_SCORE_API_KEY=your_global_wine_score_api_key_here
GLOBAL_WINE_SCORE_BASE_URL=https://api.globalwinescore.com/v1
ENABLE_GLOBAL_WINE_SCORE=false

# API Cache Configuration (in milliseconds, default is 24 hours)
API_CACHE_DURATION=86400000

# Database Configuration
DB_NAME=WineCollectionDB
CACHE_DB_NAME=WineApiCache
DB_VERSION=1
CACHE_DB_VERSION=1

# App Configuration
REACT_APP_AUTO_REFRESH_INTERVAL=30000